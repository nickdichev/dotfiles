layout {
  default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="frontend" focus=true cwd="~/Workspace/portal/cms-frontend/" {
        pane
    }

    tab name="backend" cwd="~/Workspace/portal/cms-backend/" {
        pane
    }

    tab name="servers" split_direction="vertical" {
        pane {
            cwd "~/Workspace/portal/cms-frontend"
            command "devenv"
            args "up"
        }
        pane {
            cwd "~/Workspace/portal/cms-backend"
            command "devenv"
            args "up"
        }
    }
}

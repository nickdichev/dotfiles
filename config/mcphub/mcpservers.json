{
  "nativeMCPServers": [],
  "mcpServers": {
    "sequential-thinking": {
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "command": "npx",
      "disabled": false
    },
    "portal_cms_postgres": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://postgres:postgres@127.0.0.1:54322/postgres"
      ],
      "command": "npx",
      "disabled": false
    },
    "browsertools": {
      "args": ["-y", "@agentdeskai/browser-tools-mcp@latest"],
      "command": "npx",
      "disabled": false
    },
    "nodejs-debugger": {
      "args": ["-y", "@hyperdrive-eng/mcp-nodejs-debugger"],
      "command": "npx",
      "disabled": false
    },
    "kagi": {
      "disabled": false,
      "args": ["kagimcp"],
      "command": "uvx",
      "env": {
        "KAGI_API_KEY": "$: rbw get KAGI_API_KEY_PERSONAL"
      }
    },
    "context7": {
      "args": ["-y", "@upstash/context7-mcp"],
      "command": "npx",
      "disabled": false
    }
  }
}
